rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Used for reads — checks the stored uid field
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Used for writes — checks the incoming uid field
    function incomingUidMatchesUser() {
      return request.auth.uid == request.resource.data.uid;
    }

    function isValidUser() {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Full create: must include uid + email matching the logged-in user
      allow create: if isOwner(userId) && isValidUser() && incomingUidMatchesUser();
      // Partial merge (e.g. linking GitHub): only require ownership
      allow update: if isOwner(userId);
    }

    match /dailyActivities/{activityId} {
      allow read: if isAuthenticated();
      // Create: incoming data must include uid that matches logged-in user
      allow create: if isAuthenticated() && incomingUidMatchesUser();
      // Update/merge: only the document owner can update
      allow update: if isDocOwner();
    }

    match /insights/{insightId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && incomingUidMatchesUser();
      allow update: if isDocOwner();
    }

    match /reports/{reportId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && incomingUidMatchesUser();
      allow update: if isDocOwner();
    }
  }
}
